{
   "action": {
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "copy-as-markdown": {
         "description": "Copy current page as clean markdown",
         "suggested_key": {
            "default": "Ctrl+Shift+T",
            "mac": "Ctrl+T"
         }
      }
   },
   "content_scripts": [ {
      "js": [ "content-scripts/content.js", "content-scripts/save-selection.js" ],
      "matches": [ "*://*/*" ]
   } ],
   "description": "Copy any webpage/YouTube subtitle as clean markdown",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icon/128.png",
      "16": "icon/16.png",
      "32": "icon/32.png",
      "48": "icon/48.png",
      "96": "icon/96.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "cpdown",
   "options_ui": {
      "page": "options.html"
   },
   "permissions": [ "activeTab", "clipboardWrite", "contextMenus", "scripting", "storage" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.6",
   "version_name": "1.6 alpha",
   "web_accessible_resources": [ {
      "matches": [ "*://*.youtube.com/*" ],
      "resources": [ "youtube-main-world.js" ]
   } ]
}
